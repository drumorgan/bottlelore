# Serve index.php for root directory (SPA entry point)
DirectoryIndex index.php

# Force HTTPS + normalize to www
RewriteEngine On

# Redirect non-www to www (before HTTPS check so both get fixed in one redirect)
RewriteCond %{HTTP_HOST} ^bottlelore\.com$ [NC]
RewriteRule ^(.*)$ https://www.bottlelore.com/$1 [L,R=301]

# Force HTTPS (for www.bottlelore.com)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Never rewrite JS/CSS asset requests to index.php — return real 404 instead
# (prevents 'text/html is not a valid JavaScript MIME type' errors)
RewriteRule \.(js|css|map)$ - [L]

# SPA routing — send all requests to index.php
# Except real files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# Cache headers for JS assets (wrapped in IfModule so missing mod_headers won't 500)
<IfModule mod_headers.c>
  # No-cache for source JS modules
  <FilesMatch "\.js$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  # Long cache for Vite-hashed production bundles (overrides above for *.min.js)
  <FilesMatch "\.min\.js$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
